e":"text"},{"type":"text","text":" "},{"text":"be able to react to that action. That can cause subtle bugs.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"’d"},{"text":" ","type":"text"},{"text":"out.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Automatically ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"s out child state when an action is sent for alerts and confirmation"},{"type":"text","text":" "},{"type":"text","text":"dialogs."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q","isActive":true,"type":"reference"},{"type":"text","text":" for a more advanced operator suited"},{"type":"text","text":" "},{"type":"text","text":"to navigation."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/scope\/iflet(_:action:then:fileid:filepath:line:column:)-72icx"]}],"kind":"symbol","references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Scope":{"type":"topic","url":"\/documentation\/composablearchitecture\/scope","role":"symbol","abstract":[{"text":"Embeds a child reducer in a parent domain.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"Scope"}],"title":"Scope","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Scope"}],"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Scope","kind":"symbol"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/Reducer":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text