ill","type":"text"},{"type":"text","text":" "},{"text":"emit runtime warnings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This can happen if another reducer in the parent domain changes the child state to an"},{"type":"text","text":" "},{"type":"text","text":"unrelated case when it handles the action "},{"type":"emphasis","inlineContent":[{"type":"text","text":"before"}]},{"text":" the scoped reducer runs. For example, a","type":"text"},{"type":"text","text":" "},{"text":"parent may receive a dismissal action from the child domain:","type":"text"}],"type":"paragraph"},{"code":["Reduce { state, action in","  switch action {","  case .loggedIn(.quitButtonTapped):","    state = .loggedOut(LoggedOut.State())","  \/\/ ...","  }","}","Scope(state: \\.loggedIn, action: \\.loggedIn) {","  LoggedIn()  \/\/ ⚠️ Logged-in domain can't handle `quitButtonTapped`","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If the parent domain contains additional logic for switching between cases of child state,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"prefer "},{"type":"codeVoice","code":"Reducer\/ifCaseLet(_:action:then:fileID:line:)-3k4yb"},{"text":", which better ensures that","type":"text"},{"text":" ","type":"text"},{"text":"child logic runs ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"before"}]},{"text":" any parent logic can replace child state:","type":"text"}]},{"type":"codeListing","code":["Reduce { state, action in","  switch action {","  case .loggedIn(.quitButtonTapped):","    state = .loggedOut(LoggedOut.State())","  \/\/ ...","  }","}",".ifCaseLet(\\.loggedIn, action: \\.loggedIn) {","  LoggedIn()  \/\/ ✅ Receives actions before its case can change","}"],"syntax":"swift"}],"style":"warning","type":"aside"}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Scope/init(state:action:child:fileID:filePath:line:column: