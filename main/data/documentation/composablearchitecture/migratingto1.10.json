{"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.10"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/composablearchitecture\/migratingto1.10"]}],"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The Composable Architecture is under constant development, and we are always looking for ways to"},{"text":" ","type":"text"},{"text":"simplify the library, and make it more powerful. This version of the library only introduced new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"APIs and did not deprecate any existing APIs."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Before following this migration guide be sure you have fully migrated to the newest","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tools of version 1.9. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"},{"type":"text","text":" for more information."}]}],"type":"aside","style":"important","name":"Important"},{"text":"Sharing state","level":2,"type":"heading","anchor":"Sharing-state"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The new tools added are concerned with allowing one to seamlessly share state with many parts of an"},{"type":"text","text":" "},{"text":"application that is easy to understand, and most importantly, testable. See the dedicated","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/SharingState","isActive":true},{"text":" article for more information on how to use these new tools.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To share state in one feature with another feature, simply use the ","type":"text"},{"code":"Shared","type":"codeVoice"},{"type":"text","text":" property wrapper:"}]},{"code":["@ObservableState","struct State {","  @Shared var signUpData: SignUpData","  \/\/ ...","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This will require that ","type":"text"},{"type":"codeVoice","code":"SignUpData"},{"type":"text","text":" be passed in from the parent, and any changes made to this state"},{"type":"text","text":" "},{"type":"text","text":"will be instantly observed by all features holding onto it."}]},{"inlineContent":[{"type":"text","text":"Further, there are persistence strategies one can employ in "},{"type":"codeVoice","code":"@Shared"},{"text":". For example, if you want any","type":"text"},{"type":"text","text":" "},{"type":"text","text":"changes of "},{"type":"codeVoice","code":"signUpData"},{"text":" to be automatically persisted to the file system you can use","type":"text"},{"type":"text","text":" "},{"code":"fileStorage(_:decoder:encoder:)","type":"codeVoice"},{"type":"text","text":" and specify a URL:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@ObservableState","struct State {","  @Shared(.fileStorage(URL(\/* ... *\/) var signUpData = SignUpData()","  \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Upon app launch the "},{"code":"signUpData","type":"codeVoice"},{"type":"text","text":" will be populated from disk, and any changes made to "},{"type":"codeVoice","code":"signUpData"},{"type":"text","text":" "},{"type":"text","text":"will automatically be persisted to disk. Further, if the disk version changes, all instances of"},{"text":" ","type":"text"},{"code":"signUpData","type":"codeVoice"},{"text":" in the application will automatically update.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There is another persistence strategy for storing simple data types in user defaults, called","type":"text"},{"type":"text","text":" "},{"code":"appStorage","type":"codeVoice"},{"text":". It can refer to a value in user defaults by a string","type":"text"},{"text":" ","type":"text"},{"text":"key:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@ObservableState ","struct State {","  @Shared(.appStorage(\"isOn\")) var isOn = false","  \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"text":"Similar to ","type":"text"},{"type":"codeVoice","code":"fileStorage(_:decoder:encoder:)"},{"type":"text","text":", upon launch of the application the initial"},{"text":" ","type":"text"},{"text":"value of ","type":"text"},{"type":"codeVoice","code":"isOn"},{"type":"text","text":" will be populated from user defaults, and any change to "},{"code":"isOn","type":"codeVoice"},{"type":"text","text":" will be automatically"},{"text":" ","type":"text"},{"type":"text","text":"persisted to user defaults. Further, if the user defaults value changes, all instances of "},{"code":"isOn","type":"codeVoice"},{"text":" ","type":"text"},{"text":"in the application will automatically update.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"That is the basics of sharing data. Be sure to see the dedicated ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/SharingState"},{"text":" article","type":"text"},{"type":"text","text":" "},{"text":"for more detailed information.","type":"text"}]}]}],"sections":[],"metadata":{"title":"Migrating to 1.10","modules":[{"name":"ComposableArchitecture"}],"role":"article","roleHeading":"Article"},"abstract":[{"type":"text","text":"Update your code to make use of the new state sharing tools in the library, such as the "},{"type":"codeVoice","code":"Shared"},{"text":" ","type":"text"},{"text":"property wrapper, and the ","type":"text"},{"type":"codeVoice","code":"appStorage"},{"type":"text","text":" and "},{"type":"codeVoice","code":"fileStorage"},{"type":"text","text":" persistence strategies."}],"seeAlsoSections":[{"identifiers":["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17.1","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.17","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.16","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.15","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.14","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.12","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.11","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.9","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.8","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.7","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.6","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.5","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.4"],"generated":true}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/IfLetStore":{"navigatorTitle":[{"text":"IfLetStore","kind":"identifier"}],"role":"symbol","url":"\/documentation\/composablearchitecture\/ifletstore","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/IfLetStore","abstract":[{"type":"text","text":"A view that safely unwraps a store of opt