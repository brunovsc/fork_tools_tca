ation\/ComposableArchitecture\/Shared","type":"reference"},{"type":"text","text":" property wrapper:"}],"type":"paragraph"},{"code":["@ObservableState","struct State {","  @Shared var signUpData: SignUpData","  \/\/ ...","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This will require that ","type":"text"},{"type":"codeVoice","code":"SignUpData"},{"text":" be passed in from the parent, and any changes made to this state","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be instantly observed by all features holding onto it."}],"type":"paragraph"},{"inlineContent":[{"text":"Further, there are persistence strategies one can employ in ","type":"text"},{"type":"codeVoice","code":"@Shared"},{"text":". For example, if you want any","type":"text"},{"type":"text","text":" "},{"text":"changes of ","type":"text"},{"type":"codeVoice","code":"signUpData"},{"text":" to be automatically persisted to the file system you can use the","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PersistenceReaderKey\/fileStorage(_:decoder:encoder:)","isActive":true,"type":"reference"},{"text":" and specify a URL:","type":"text"}],"type":"paragraph"},{"code":["@ObservableState","struct State {","  @Shared(.fileStorage(URL(\/* ... *\/) var signUpData = SignUpData()","  \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Upon app launch the "},{"type":"codeVoice","code":"signUpData"},{"type":"text","text":" will be populated from disk, and any changes made to "},{"code":"signUpData","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"will automatically be persisted to disk. Further, if the disk version changes, all instances of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"signUpData"},{"type":"text","text":" in the application will automatically update."}],"type":"paragraph"},{"type":"paragraph","inlineCon