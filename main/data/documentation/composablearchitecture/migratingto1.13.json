{"variants":[{"paths":["\/documentation\/composablearchitecture\/migratingto1.13"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture","doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigrationGuides"]]},"abstract":[{"type":"text","text":"The Composable Architecture now provides first class tools for building features in UIKit,"},{"text":" ","type":"text"},{"text":"including minimal state observation, presentation and stack navigation.","type":"text"}],"sections":[],"metadata":{"title":"Migrating to 1.13","role":"article","roleHeading":"Article","modules":[{"name":"ComposableArchitecture"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/MigratingTo1.13"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"text":"The Composable Architecture is now integrated with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/github.com\/pointfreeco\/swift-navigation"},{"type":"text","text":" library,"},{"type":"text","text":" "},{"text":"which brings powerful navigation and observation tools to UIKit. You can model your domains","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as concisely as possible, just as you would in SwiftUI, but then implement your view in UIKit"},{"type":"text","text":" "},{"type":"text","text":"without losing any power."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The simplest tool to use is "},{"code":"observe","type":"codeVoice"},{"type":"text","text":", which allows you to minimally observe changes to state in"},{"type":"text","text":" "},{"type":"text","text":"your feature and update the UI. Typically the best place to do this is in "},{"code":"viewDidLoad","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["let store: StoreOf<Feature>","","func viewDidLoad() {","  super.viewDidLoad()","","  \/\/ ...","","  observe { [weak self] in","    countLabel.text = \"Count: \\(store.count)\"","  }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Only the state accessed in the "},{"code":"observe","type":"codeVoice"},{"type":"text","text":" trailing closure will be observed. If any other state"},{"type":"text","text":" "},{"type":"text","text":"changes, the closure will not be invoked and no extra work will be performed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The library also provides powerful navigation tools for UIKit. For example, suppose you have a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"feature that can present a child feature (see the docs on "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TreeBasedNavigation","isActive":true,"overridingTitleInlineContent":[{"text":"tree-based","type":"text"},{"type":"text","text":" "},{"type":"text","text":"navigation"}],"overridingTitle":"tree-based navigation","type":"reference"},{"text":" for more information on these tools):","type":"text"}]},{"syntax":"swift","code":["@Reducer ","struct Feature {","  @ObservableState","  struct State {","    @Presents var child: ChildFeature.State?","    \/\/ ...","  }","  \/\/ ...","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then you can present a view controller when the child state flips to a non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" value by using the"},{"type":"text","text":" "},{"code":"present(item:)","type":"codeVoice"},{"text":" API that comes with the library:","type":"text"}]},{"code":["@UIBindable var store: StoreOf<Feature>","","func viewDidLoad() {","  super.viewDidLoad()","","  present(item: $store.scope(state: \\.child, action: \\.child)) { store in","    ChildViewController(store: store)","  }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Further, if your feature has a stack of features that can be presented, then you can model your","type":"text"},{"type":"text","text":" "},{"text":"domain like so (see the docs on ","type":"text"},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"stack-based"}],"overridingTitle":"stack-based","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackBasedNavigation"},{"type":"text","text":" for more information"},{"type":"text","text":" "},{"text":"on these tools):","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["@Reducer","struct AppFeature {","  struct State {","    var path = StackState<Path.State>()","    \/\/ ...","  }","","  @Reducer","  enum Path {","    case addItem(AddFeature)","    case detailItem(DetailFeature)","    case editItem(EditFeature)","  }","","  \/\/ ...","}"],"syntax":"swift"},{"inlineContent":[{"text":"And for the view you can subclass ","type":"text"},{"code":"NavigationStackController","type":"codeVoice"},{"type":"text","text":" in order to drive navigation from the"},{"text":" ","type":"text"},{"text":"stack state:","type":"text"}],"type":"paragraph"},{"code":["class AppController: NavigationStackController {","  private var store: StoreOf<AppFeature>!","","  convenience init(store: StoreOf<AppFeature>) {","    @UIBindable var store = store","","    self.init(path: $store.scope(state: \\.path, action: \\.path)) {","      RootViewController(store: store)","    } destination: { store in ","      switch store.case {","      case .addItem(let store):","        AddViewController(store: store)","      case .detailItem(let store):","        DetailViewController(store: store)","      case .editItem(let store):","        EditViewController(store: store)","      }","    }","","    self.store = store","  }","}"],"type":"c