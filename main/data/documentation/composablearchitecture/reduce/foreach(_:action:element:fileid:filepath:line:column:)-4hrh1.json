e"},{"content":[{"inlineContent":[{"text":"The column.","type":"text"}],"type":"paragraph"}],"name":"column"}]},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}]}],"kind":"content"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"For example, if a parent feature holds onto an array of child states, then it can perform"},{"text":" ","type":"text"},{"text":"its core logic ","type":"text"},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"type":"text","text":" the child’s logic by using the "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"code":["@Reducer","struct Parent {","  struct State {","    var rows: IdentifiedArrayOf<Row.State>","    \/\/ ...","  }","  enum Action {","    case rows(IdentifiedActionOf<Row>)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .forEach(\\.rows, action: \\.rows) {","      Row()","    }","  }","}"],"syntax":"swift","type":"codeListing"},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"We are using ","type":"text"},{"type":"codeVoice","code":"IdentifiedArray"},{"text":" from our","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/github.com\/pointfreeco\/swift-identified-collections","type":"reference","isActive":true},{"type":"text","text":" library because it provides a safe"},{"type":"text","text":" "},{"text":"and ergonomic API for accessing elements from a stable ID rather than positional indices.","type":"text"}]}],"type":"aside","name":"Tip"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"forEach"},{"text":" forces 