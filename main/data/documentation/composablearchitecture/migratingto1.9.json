t","text":"action:"}]},{"syntax":"swift","code":["store.receive(\\.child.presented.success, \"Hello\")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Version 1.9 introduces similar affordances for "},{"type":"emphasis","inlineContent":[{"text":"sending","type":"text"}]},{"text":" actions to test stores via","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"TestStore\/send(_:assert:fileID:file:line:column:)-8877x"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore\/send(_:_:assert:fileID:file:line:column:)","type":"reference"},{"text":". These methods can significantly simplify","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"integration-style tests that send deeply-nested actions to child features, and provide symmetry to"},{"text":" ","type":"text"},{"type":"text","text":"how actions are received:"}]},{"type":"codeListing","code":["-store.send(.path(.element(id: 0, action: .destination(.presented(.record(.startButtonTapped))))))","+store.send(\\.path[id: 0].destination.record.startButtonTapped)"," store.receive(\\.path[id: 0].destination.record.timerTick)"],"syntax":"diff"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Case key paths offer specialized syntax for many different action types."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction"},{"type":"text","text":"’s "},{"type":"codeVoice","code":"presented"},{"type":"text","text":" case can be collapsed:"}]},{"type":"codeListing","code":["-store.send(.destination(.presented(.tap)))","+store.send(\\.destination.tap)"],"syntax":"diff"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/ComposableArchitecture\/docume