ility to assert against the payload of a received","type":"text"},{"type":"text","text":" "},{"text":"action:","type":"text"}]},{"syntax":"swift","code":["store.receive(\\.child.presented.success, \"Hello\")"],"type":"codeListing"},{"inlineContent":[{"text":"Version 1.9 introduces similar affordances for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"sending","type":"text"}]},{"type":"text","text":" actions to test stores via"},{"type":"text","text":" "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore\/send(_:assert:fileID:file:line:column:)-8877x","isActive":true,"type":"reference"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/TestStore\/send(_:_:assert:fileID:file:line:column:)","isActive":true,"type":"reference"},{"type":"text","text":". These methods can significantly simplify"},{"text":" ","type":"text"},{"text":"integration-style tests that send deeply-nested actions to child features, and provide symmetry to","type":"text"},{"text":" ","type":"text"},{"text":"how actions are received:","type":"text"}],"type":"paragraph"},{"code":["-store.send(.path(.element(id: 0, action: .destination(.presented(.record(.startButtonTapped))))))","+store.send(\\.path[id: 0].destination.record.startButtonTapped)"," store.receive(\\.path[id: 0].destination.record.timerTick)"],"type":"codeListing","syntax":"diff"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Case key paths offer specialized syntax for many different action types."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/PresentationAction","isActive":true},{"text":"’s ","type":"text"},{"type":"codeVoice","code":"presented"},{"type":"text","text":" case can be collapsed:"}]},{"syntax":"diff","code":