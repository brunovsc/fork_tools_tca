kind":"text"},{"kind":"typeIdentifier","text":"ViewAction"},{"text":") -> ","kind":"text"},{"text":"Action","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"removeDuplicates","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"isDuplicate"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"ViewState"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"ViewState"},{"text":") -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"@","kind":"attribute"},{"text":"ViewBuilder","preciseIdentifier":"s:7SwiftUI11ViewBuilderV","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"externalParam","text":"content"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:22ComposableArchitecture9ViewStoreC","text":"ViewStore","kind":"typeIdentifier","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewStore"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"ViewState"},{"text":", ","kind":"text"},{"text":"ViewAction","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"file","kind":"externalParam"},{"kind":"text","text":": "},{"text":"StaticString","kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV"},{"kind":"text","text":" = "},{"text":"#fileID","kind":"keyword"},{"kind":"text","text":", "},{"text":"line","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UInt","preciseIdentifier":"s:Su","kind":"typeIdentifier"},{"text":" = ","kind":"text"},{"text":"#line","kind":"keyword"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"store","content":[{"inlineContent":[{"type":"text","text":"A store."}],"type":"paragraph"}]},{"name":"toViewState","content":[{"inlineContent":[{"text":"A function that transforms store state into observable view state. All","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"changes to the view state will cause the "},{"code":"WithViewStore","type":"codeVoice"},{"text":" to re-compute its view.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that transforms view actions into store action."}]}],"name":"fromViewAction"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function to determine when two "},{"type":"codeVoice","code":"ViewState"},{"text":" values are equal. When values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are equal, repeat view computations are removed."}]}],"name":"isDuplicate"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that can generate content from a view store."}]}],"name":"content"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","isActive":true},{"text":" will re-compute its body for ","type":"text"},{"inlineContent":[{"text":"any","type":"text"}],"type":"emphasis"},{"type":"text","text":" change to the state it holds. Often the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference"},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"text":" ","type":"text"},{"type":"text","text":"view. It may hold onto the state of child features, or internal state for its logic."}]},{"inlineContent":[{"text":"It can be important to transform the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true},{"text":"’s state into something smaller for observation.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This will help minimize the number of times your view re-computes its body, and can even avoid"},{"text":" ","type":"text"},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The way to do this is to use the "},{"code":"observe","type":"codeVoice"},{"type":"text","text":" argument of this initializer. It allows you to"},{"type":"text","text":" "},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"text":" ","type":"text"},{"text":"a body re-computation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"type":"text","text":" "},{"text":"for each tab as well as the currently selected tab:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"]},{"inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"type":"text","text":" "},{"type":"codeVoice","code":"selectedTab"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"text":" ","type":"text"},{"text":"need to observe changes to ","type":"text"},{"type":"codeVoice","code":"activity"},{"type":"text","text":", "},{"code":"search","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"profile"},{"type":"text","text":". Those are only necessary for"},{"type":"text","text":" "},{"text":"those child features, and changes to that state should not cause our tab view to re-compute","type":"text"},{"type":"text","text":" "},{"type":"text","text":"itself."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"]},{"inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","isActive":true,"type":"reference"},{"type":"text","text":" article."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/Performance":{"abstract":[{"type":"text","text":"Learn how to improve the performance of features built in the Composable Architecture."}],"type":"topic","url":"\/documentation\/composablearchitecture\/performance","kind":"article","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","title":"Performance","role":"article"},"doc://ComposableArchitecture/documentation/ComposableArchitecture/WithViewStore/init(_:observe:content:file:line:)-8g15l":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"